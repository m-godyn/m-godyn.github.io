---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Projects | Miłosz Godyń" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  <HorizontalCard
    title="ASCII Art"
    img="/projects/ascii-art.webp"
    desc="Transform your images into stunning ASCII representations directly from the terminal!"
    url="https://github.com/m-godyn/ascii-art"
    badge="NEW"
  />
</BaseLayout>
